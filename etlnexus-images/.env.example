# === Database ===
DATABASE_URL=postgresql+asyncpg://etlnexus:etlnexus@db:5432/etlnexus
# Prod: set a strong password, must match POSTGRES_PASSWORD below
POSTGRES_PASSWORD=etlnexus
# PostgreSQL container database name and user (used by docker-compose)
POSTGRES_DB=etlnexus
POSTGRES_USER=etlnexus
# Connection pool tuning (backend only)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_COMMAND_TIMEOUT=30
# DB_ECHO=false

# === Airflow Integration ===
# Dev: points to local Airflow container
# Prod: set to your Airflow instance URL (e.g., https://airflow.company.com/api/v1)
AIRFLOW_BASE_URL=http://airflow-webserver:8080/api/v1
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_POLL_INTERVAL_MINUTES=20
# Operator types to skip during auto-discovery (comma-separated)
AIRFLOW_EXCLUDE_OPERATOR_TYPES=EmptyOperator,BranchPythonOperator,TriggerDagRunOperator,ShortCircuitOperator
# Tuning: concurrent Airflow API requests and startup retry behavior
AIRFLOW_SEMAPHORE_LIMIT=6
AIRFLOW_STARTUP_MAX_ATTEMPTS=20
AIRFLOW_STARTUP_RETRY_SECONDS=15
# Circuit breaker: number of consecutive failures before backing off
AIRFLOW_CB_THRESHOLD=5
AIRFLOW_CB_COOLDOWN_SECONDS=30
# Number of pipelines to process per sync batch
AIRFLOW_SYNC_CHUNK_SIZE=50
# Infer lineage from DAG graph structure instead of task params
INFER_LINEAGE_FROM_DAG_GRAPH=false

# === Spark Connect (Iceberg catalog access) ===
# Backend reads Iceberg table schemas through a Spark Connect server (no REST catalog).
# Dev: the spark-connect container. Prod: set to your Spark Connect endpoint.
SPARK_CONNECT_URL=sc://spark-connect:15002
# Spark catalog alias holding the Iceberg tables (used in SQL: <catalog>.<ns>.<table>)
SPARK_CATALOG_NAME=iceberg
SPARK_NAMESPACE_PREFIX=dagger,prism,vault,oasis
# Iceberg hadoop-catalog warehouse path, shared by the Spark Connect server, DAGs and seeds
SPARK_WAREHOUSE=/tmp/warehouse

# === AI / LLM ===
# Set your OpenAPI-compatible endpoint (e.g., https://api.openai.com/v1)
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=default
LLM_MAX_TOKENS=1024

# === Spark Cluster Capacity ===
# Maximum resource limits for capacity utilization display
SPARK_MAX_DRIVER_MEMORY_GB=16
SPARK_MAX_EXECUTOR_MEMORY_GB=64
SPARK_MAX_EXECUTOR_CORES=32
SPARK_MAX_TOTAL_EXECUTORS=20

# === Cache & Pagination ===
CACHE_TTL_SHORT=30
CACHE_TTL_MEDIUM=60
CACHE_TTL_AIRFLOW=300
DEFAULT_PAGE_LIMIT=200
DEFAULT_PAGE_LIMIT_SMALL=20

# === Redis (Optional) ===
# Cross-instance cache invalidation via pub/sub
# Leave empty to disable (each instance manages its own cache independently)
REDIS_URL=
# Prod example: redis://redis:6379/0

# === Oasis Prod (External Usage Metrics) ===
# Connection to the production observation database for live read metrics
# Leave empty to disable (usage metrics will show zeros)
OASIS_PROD_DATABASE_URL=
# Prod example: postgresql+asyncpg://oasis-prod.internal:5432/oasis_prod
OASIS_PROD_USERNAME=
OASIS_PROD_PASSWORD=
OASIS_PROD_POOL_SIZE=5
OASIS_PROD_MAX_OVERFLOW=3

# === App ===
# Prod: set to your frontend domain (e.g., ["https://etlnexus.company.com"])
CORS_ORIGINS=["http://localhost:5173"]
DEBUG=true
DEPLOYMENT_ENV=development
TRUSTED_PROXY_DEPTH=1
SCHEDULER_ENABLED=true
LOG_FORMAT=auto

# === Retention ===
RUN_HISTORY_RETENTION_DAYS=90

# === Frontend ===
# Airflow UI URL used for links in the frontend (default: http://localhost:8080)
VITE_AIRFLOW_URL=http://localhost:8080

# === SSO / OIDC (Keycloak) ===
# SSO_ISSUER_URL / SSO_PUBLIC_ISSUER_URL must match your Keycloak realm URL
# In production, both should point to the public-facing Keycloak URL
SSO_ENABLED=true
SSO_ISSUER_URL=http://keycloak:8090/realms/etlnexus
SSO_CLIENT_ID=etlnexus-app
SSO_AUDIENCE=etlnexus-app
SSO_GROUPS_CLAIM=groups
SSO_ROLE_CLAIM=realm_access.roles
SSO_ADMIN_ROLE=admin
SSO_PUBLIC_ISSUER_URL=http://localhost:8090/realms/etlnexus
