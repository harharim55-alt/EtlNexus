# === Database ===
DATABASE_URL=postgresql+asyncpg://etlnexus:etlnexus@db:5432/etlnexus
# Prod: set a strong password, must match POSTGRES_PASSWORD below
POSTGRES_PASSWORD=etlnexus

# === Airflow Integration ===
# Dev: points to local Airflow container
# Prod: set to your Airflow instance URL (e.g., https://airflow.company.com/api/v1)
AIRFLOW_BASE_URL=http://airflow-webserver:8080/api/v1
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_POLL_INTERVAL_MINUTES=20

# === Git Integration ===
# Dev: local volume path seeded with sample ETLs
# Prod: set to your Git repo URL (HTTPS)
GIT_REPO_URL=/data/dev-repo
GIT_BRANCH=main
GIT_PULL_INTERVAL_MINUTES=60
# Prod: GitHub PAT or access token for private HTTPS repos
GIT_HTTPS_TOKEN=

# === Iceberg Catalog ===
# Dev: local Iceberg REST catalog container
# Prod: set to your Iceberg REST catalog URL
ICEBERG_CATALOG_URI=http://iceberg-rest:8181
ICEBERG_NAMESPACE_PREFIX=dagger

# === AI / LLM ===
# Set your OpenAPI-compatible endpoint (e.g., https://api.openai.com/v1)
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=default
LLM_MAX_TOKENS=1024

# === ETL DAGs ===
# Python module path containing get_etl_dags function
ETL_DAGS_MODULE=etl_dags

# === App ===
# Prod: set to your frontend domain (e.g., ["https://etlnexus.company.com"])
CORS_ORIGINS=["http://localhost:5173"]
DEBUG=true
